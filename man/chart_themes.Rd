\details{
\subsection{Available Themes}{

\describe{
\item{\code{default}}{A dark theme with cyan and steel-blue tones. Light
(\verb{#E0FFFF}) bullish candles on a near-black (\verb{#141414}) background
with a cool blue (\verb{#4682B4}) bearish candle. The colorway spans
icy blues through teal and soft purple.}
\item{\code{hawks_and_doves}}{A light, grayscale theme with a white background.
Candles use shades of gray, making it suitable for print or
presentations where color is secondary. The colorway uses muted,
accessible tones.}
\item{\code{payout}}{A dark teal theme on a near-black (\verb{#1A1A1A}) background.
Bullish candles are teal (\verb{#008080}), bearish candles are dark slate
(\verb{#2F4F4F}). The colorway follows the default Plotly palette.}
\item{\code{tp_slapped}}{A bright theme on a light gray (\verb{#ECF0F1})
background. Red (\verb{#E74C3C}) bearish and teal (\verb{#1ABC9C}) bullish
candles provide strong visual contrast. The colorway uses vivid,
saturated colors.}
\item{\code{trust_the_process}}{A subtle, earth-toned theme on a light gray
(\verb{#F5F5F5}) background. Both bull and bear candles use shades of gray,
keeping the focus on indicator lines. The colorway uses muted natural
tones.}
\item{\code{bloomberg_terminal}}{A dark theme on a near-black (\verb{#0E1017})
background with orange (\verb{#FF8F40}) bullish and neutral-gray
(\verb{#BBB9B2}) bearish candles. Inspired by the Bloomberg Terminal
interface. Colorblind-friendly (see below).}
\item{\code{limit_up}}{A dark monochrome theme on a near-black (\verb{#121212})
background. Candles use only luminance to encode direction (light-gray
bullish vs dark-gray bearish). Colorblind-friendly (see below).}
\item{\code{bid_n_ask}}{A light theme on an azure (\verb{#F0FFFF}) background
with steel-blue (\verb{#4682B4}) bullish and tomato-red (\verb{#FF6347})
bearish candles. The classic blue-vs-red trading pair.
Colorblind-friendly (see below).}
}
